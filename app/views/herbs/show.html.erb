<div class="min-h-screen bg-gradient-to-br flex flex-col items-center justify-center p-4 space-y-3 w-full">
<%= render 'shared/header' %>
<div class="max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
<h1 class="text-2xl text-herb-green-700 mb-4"><%= @herb.name %></h1>

<hr class="border-herb-green-200 mb-3">

  <div class="flex gap-4 mb-6 justify-center">

    <% if @herb.image.attached? %>
      <%= image_tag @herb.image,
        class: "w-24 h-24 object-cover rounded-xl" %>
    <% else %>
      <div class="w-24 h-24 bg-herb-green-100 rounded-xl flex items-center justify-center">
        <span class="text-xs text-herb-green-700/50">画像なし</span>
      </div>
    <% end %>
    <div>
      <p class="text-sm text-herb-green-700/60">タグ</p>
      <p><%= "@herb.tags" %></p>
    </div>
  </div>

  <div class="space-y-4">
    <div>
      <p class="text-sm text-herb-green-700/60">説明</p>
      <p><%= @herb.description %></p>
    </div>
    <div>
      <p class="text-sm text-herb-green-700/60">禁忌</p>
      <p><%= @herb.caution %></p>
    </div>
  </div>

  <br>
  <%= link_to "一覧に戻る", herbs_path,
    class:"inline-block border rounded-full px-6 py-2" %>

</div>
<%= render 'shared/footer' %>